# ---- Usha Shop environment ----
# Copy to .env.local for local dev, and set the same keys in Vercel project settings.
# NOTE: set values in Vercel with `printf "%s" "value" | vercel env add NAME`
# (echo appends a trailing newline that silently breaks URLs/keys).

# Public base URL of the store (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://shop.usha.se

# ---- Usha Platform session bridge (Phase 1, optional) ----
# When set, a logged-in usha.se user is recognised on the shop (shared .usha.se
# cookie): their email is prefilled at checkout and a "signed in as" badge shows.
# All three must be set together to activate; leave blank for guest-only.
#   - Supabase project's public URL + anon (publishable) key, SAME project as
#     usha.se. The anon key is public/safe to expose.
#   - NEXT_PUBLIC_COOKIE_DOMAIN must be ".usha.se", AND the platform must set the
#     same value, so the auth cookie is shared across both subdomains.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_COOKIE_DOMAIN=

# ---- Member discounts (Phase 2, off during free beta) ----
# When "true", logged-in Guld members get 10% off and Premium members 20% off
# at checkout (as a Stripe coupon line). Leave unset/false during the free beta.
# Flip to "true" on BOTH the shop and the platform when memberships become paid.
NEXT_PUBLIC_DISCOUNTS_ENABLED=

# ---- Stripe (platform account — same account as usha.se) ----
# Use TEST keys locally, LIVE keys in production.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret from the Stripe dashboard endpoint (see CHECKLIST.md).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Fulfillment: CJdropshipping ----
# From CJ dashboard → Authorization → API. When both are set, the webhook
# places orders with CJ automatically; otherwise it just logs the order.
CJ_API_EMAIL=you@usha.se
CJ_API_KEY=cj_api_key_xxx
# Optional: warehouse to ship from (e.g. "DE" for the EU warehouse) and the
# CJ shipping method label (e.g. "CJPacket Ordinary"). Leave blank to let CJ pick.
CJ_FROM_COUNTRY=
CJ_LOGISTIC_NAME=
# Fallback notification target (audit / manual replay).
FULFILLMENT_NOTIFY_EMAIL=pablo.acosta@usha.se
